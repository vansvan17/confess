# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://confess:confess@localhost:5432/confess

# Redis
REDIS_URL=redis://localhost:6379

# Clerk Auth
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Hugging Face (free) — get token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Confidence Scoring
WEIGHT_SIMILARITY=0.5
WEIGHT_GAP=0.3
WEIGHT_COVERAGE=0.2
CONFIDENCE_THRESHOLD=0.65
